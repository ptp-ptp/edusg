OPENAI_MODEL=gpt-4.1-mini

# Vercel sets this automatically in production
# VERCEL=1
#
# Production persistence: set SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY on Vercel,
# then run migrations and seed once:
#   npm run db:push
#   npm run setup:supabase
