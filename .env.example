# Server-side only (never expose to browser)
SUPABASE_URL=https://zitukvkmyduzacnhqcxb.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Optional: enable Google / Apple sign-in (Supabase Auth → Providers)
